      {
        "parameters": {
          "jsCode": "const input = $input.first().json;\n\nconst duraciones = {\n  \"Masaje Relajante\": 60,\n  \"Masaje Ayurveda Relajante\": 60,\n  \"Masaje Descontracturante\": 60,\n  \"Masaje Tailandés con Aceite\": 60,\n  \"Masaje de Cabeza, Cuello, Hombros y Espalda\": 60,\n  \"Masaje Lomi Lomi\": 60,\n  \"Masaje Adelgazante y Anticelulítico\": 60,\n  \"Masajes para Embarazada\": 60,\n  \"Drenaje Linfático Manual\": 60,\n  \"Masaje Zen Vital\": 60,\n  \"Masaje Balsámico\": 90,\n  \"Ritual Serena\": 60,\n  \"Masaje para Parejas\": 60,\n  \"Reflexología\": 50,\n  \"Sanación con Reiki\": 60,\n  \"Masaje Facial Japonés Kobido\": 60,\n  \"Limpieza de Piel Intensa\": 60,\n  \"Limpieza de Piel Premium\": 60,\n  \"Dermapen\": 60,\n  \"The Glow Session\": 90,\n  \"Exoxomas\": 45,\n  \"Depilación Ingles Completas\": 30,\n  \"Ingles Completas y Medias Piernas\": 60\n};\n\nconst servicio = input.servicio || \"\";\nconst duracion = duraciones[servicio] || 60;\n\n// ✅ Nombres correctos con espacio\nconst fechaNueva = $('Code in JavaScript8').first().json[\"Fecha nueva\"];\nconst horaNueva = $('Code in JavaScript8').first().json[\"Hora nueva\"];\n\nconst start_time = `${fechaNueva}T${horaNueva}:00+01:00`;\n\nconst [horas, minutos] = horaNueva.split(':').map(Number);\nconst totalMinutos = horas * 60 + minutos + duracion;\nconst horaFin = String(Math.floor(totalMinutos / 60)).padStart(2, '0');\nconst minFin = String(totalMinutos % 60).padStart(2, '0');\nconst end_time = `${fechaNueva}T${horaFin}:${minFin}:00+01:00`;\n\nreturn [{\n  json: {\n    ...input,\n    servicio,\n    duracion,\n    start_time,\n    end_time\n  }\n}];"
        },
