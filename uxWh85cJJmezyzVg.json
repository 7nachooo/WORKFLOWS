      {
        "parameters": {
          "jsCode": "const input = $input.first().json;\nconst texto = input.text || \"\";\n\n// Extraer fecha, hora y teléfono del output del LLM\nconst fecha = (texto.match(/\"fecha\"\\s*:\\s*\"([^\"]+)\"/) || [])[1] || \"\";\nconst hora = (texto.match(/\"hora\"\\s*:\\s*\"([^\"]+)\"/) || [])[1] || \"\";\nconst telefono = (texto.match(/\"telefono\"\\s*:\\s*\"([^\"]+)\"/) || [])[1] || \n                 $('Code in JavaScript8').first().json.Telefono || \"\";\n\nreturn [{\n  json: {\n    Telefono: telefono.replace(/\\s+/g, ''),\n    Fecha_nueva: $('Code in JavaScript8').first().json.Fecha_nueva,\n    Hora_nueva: $('Code in JavaScript8').first().json.Hora_nueva,\n    Fecha_anterior: $('Code in JavaScript8').first().json.Fecha_anterior,\n    Hora_anterior: $('Code in JavaScript8').first().json.Hora_anterior,\n  }\n}];"
        },
