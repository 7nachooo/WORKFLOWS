    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const call = item.json.body?.call || {};\n\n  // --- 1) Unimos todo el transcript en texto plano ---\n  const rawText = (call.transcript || \"\")\n    .normalize(\"NFD\")\n    .replace(/[\\u0300-\\u036f]/g, \"\"); // quitar tildes\n\n  // --- 2) Buscamos todas las formas de decir el correo ---\n  // soporta frases como: \"mi correo es ...\" o \"mi correo, ...\"\n  const match = rawText.match(/mi correo[^,.:\\-]*[,.:\\-]?\\s*(.+)/i);\n\n  if (!match) {\n    item.json.correo = \"\";\n    return item;\n  }\n\n  let frase = match[1].toLowerCase().trim();\n\n  // --- 3) Diccionario de números escritos ---\n  const numeros = {\n    cero: \"0\", uno: \"1\", una: \"1\", dos: \"2\", tres: \"3\",\n    cuatro: \"4\", cinco: \"5\", seis: \"6\", siete: \"7\",\n    ocho: \"8\", nueve: \"9\"\n  };\n\n  // Convertir números escritos (“siete”, “número siete”, etc.)\n  frase = frase.replace(\n    /\\b(cero|uno|una|dos|tres|cuatro|cinco|seis|siete|ocho|nueve)\\b/g,\n    m => numeros[m]\n  );\n\n  // --- 4) Frases especiales ---\n  frase = frase\n    .replace(/con dos os?/g, \"oo\")\n    .replace(/arroba/g, \"@\")\n    .replace(/punto/g, \".\")\n    .replace(/el numero/g, \"\") // ejemplo: “el número 7”\n    .replace(/el /g, \"\")       // “el siete” -> “7”\n    .replace(/,/g, \" \")\n    .replace(/ /g, \"\");\n\n  // --- 5) Filtrar caracteres válidos ---\n  frase = frase.replace(/[^a-z0-9@.]/g, \"\");\n\n  item.json.correo = frase;\n  return item;\n});\n"
      },
