      {
        "parameters": {
          "jsCode": "return items.map(item => {\n\n    // -------- 1. ORIGEN DE DATOS --------\n    const rawNombre_A = item.json.NOMBRE || \"\";\n    const rawFecha_A  = item.json.FECHA || \"\";\n    const rawCorreo_A = item.json.CORREO || \"\";\n\n    const rawSummary_B = item.json.summary || \"\";\n    const rawFecha_B   = item.json.start?.dateTime || item.json.start?.date || \"\";\n    const rawCorreo_B  = item.json.creator?.email || \"\";\n\n    // Priorizar fecha válida de Calendar\n    const rawFecha = rawFecha_B || rawFecha_A || \"\";\n    const rawCorreo = rawCorreo_A || rawCorreo_B || \"\";\n    const rawSummary = rawSummary_B || \"\";\n\n    // -------- 2. LIMPIAR TEXTO --------\n    const clean = t => (t || \"\")\n        .replace(/[\\r\\n\\t]+/g, \" \")\n        .replace(/\\s+/g, \" \")\n        .trim()\n        .toLowerCase();\n\n    const summary = clean(rawSummary);\n\n    // -------- 3. EXTRAER NOMBRE --------\n    let cliente = \"\";\n    let match = summary.match(/cita con (.+?) para/i) \n             || summary.match(/cita con (.+)$/i);\n\n    if (match) cliente = match[1].trim();\n\n    let fuenteNombre = (rawNombre_A || cliente || \"\").trim();\n\n    let nombre = \"\";\n    const partes = fuenteNombre.split(\" \").filter(Boolean);\n    if (partes.length) {\n        nombre = partes[0].charAt(0).toUpperCase() + partes[0].slice(1).toLowerCase();\n    }\n\n    // -------- 4. FECHA / HORA (SEGURA) --------\n    let fecha = \"\";\n    let hora = \"\";\n    let fechaHoraGC = \"\";\n\n    if (rawFecha) {\n        const d = new Date(rawFecha);\n\n        if (!isNaN(d.getTime())) {\n            fechaHoraGC = d.toISOString();\n\n            fecha = new Intl.DateTimeFormat(\"es-ES\", {\n                day: \"2-digit\",\n                month: \"2-digit\",\n                year: \"numeric\",\n                timeZone: \"Europe/Madrid\",\n            }).format(d);\n\n            hora = new Intl.DateTimeFormat(\"es-ES\", {\n                hour: \"2-digit\",\n                minute: \"2-digit\",\n                hour12: false,\n                timeZone: \"Europe/Madrid\",\n            }).format(d);\n        }\n    }\n\n    // -------- 5. SALIDA --------\n    item.json.nombre      = nombre;\n    item.json.fecha       = fecha;\n    item.json.hora        = hora;\n    item.json.correo      = rawCorreo;\n    item.json.fechaHoraGC = fechaHoraGC;\n    item.json.servicio    = (item.json.Servicio || \"\").trim();\n\n    return item;\n});\n"
        },
